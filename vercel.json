{
  "version": 2,
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "data/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index?path=$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/api/index?path=uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
